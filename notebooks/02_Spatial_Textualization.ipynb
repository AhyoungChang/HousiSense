import pandas as pd
import os

# 1. Helper functions for qualitative mapping
def describe_distance(dist):
    if dist < 300: return "offers immediate access to"
    if dist < 800: return "is within a short walking distance to"
    return "is easily accessible to"

def describe_crime(rank):
    if rank < 0.3: return "a very safe neighborhood with minimal crime activity"
    if rank > 0.7: return "an area with higher than average urban activity"
    return "a typical urban safety profile"

# 2. Constructing the Spatial Narrative
def generate_narrative(row):
    text = f"This property is located in the {row['neighborhood_name']} area. "
    text += f"Regarding safety, it is {describe_crime(row['crime_count_rank'])}. "
    text += f"The location {describe_distance(row['dist_park'])} local green spaces and parks. "
    text += f"Public transportation is {describe_distance(row['dist_transit'])} the nearest transit stop."
    return text

# 3. Knowledge Base Synthesis
# Merge Listing Info + Spatial Narrative + Guest Reviews
df = pd.read_csv("../data/austin_spatial_integrated.csv")
df['spatial_narrative'] = df.apply(generate_narrative, axis=1)

# Combine with processed reviews
df['final_rag_text'] = df.apply(lambda x: 
    f"[Listing {x['id']}] {x['spatial_narrative']} User Experience: {str(x['comments'])[:500]}", 
    axis=1
)

df.to_csv("../data/austin_knowledge_base_final.csv", index=False)
print("Spatial-Textual Knowledge Base constructed.")
