import matplotlib.pyplot as plt
import seaborn as sns
import pandas as pd
import numpy as np

df = pd.read_csv("../data/austin_spatial_integrated.csv")

# 1. Visualization of the 'Urban Paradox'
# Relationship between Amenity Density and Sentiment
plt.figure(figsize=(10, 6))
sns.regplot(data=df, x='poi_count', y='sentiment_score', lowess=True, 
            line_kws={'color': 'red'}, scatter_kws={'alpha': 0.3})
plt.title("The Urban Paradox: Amenity Density vs. Resident Sentiment")
plt.xlabel("Amenity Density (POI Count)")
plt.ylabel("Sentiment Score")
plt.show()

# 2. Quantitative Validation: Optimization Plot
# Proving HousiSense recommendations sit at the mathematical origin (0,0)
# (Red dot represents the system's choice against the neighborhood background)
def plot_optimization(target_id, neighborhood_df):
    plt.scatter(neighborhood_df['dist_park'], neighborhood_df['dist_transit'], c='grey', alpha=0.5)
    target = neighborhood_df[neighborhood_df['id'] == target_id]
    plt.scatter(target['dist_park'], target['dist_transit'], c='red', s=100, label='HousiSense Choice')
    plt.xlabel("Distance to Park")
    plt.ylabel("Distance to Transit")
    plt.legend()
    plt.show()
