from langchain_huggingface import HuggingFaceEmbeddings
from langchain_community.vectorstores import Chroma
from langchain.schema import Document
import pandas as pd
import os

# 1. Vector Database Construction
df = pd.read_csv("../data/austin_knowledge_base_final.csv")

# Create documents for indexing
documents = [
    Document(page_content=row['final_rag_text'], metadata={"listing_id": row['id']})
    for _, row in df.iterrows()
]

# Using high-performance embeddings
embeddings = HuggingFaceEmbeddings(model_name="sentence-transformers/all-mpnet-base-v2")

# Persist to local directory
vector_db = Chroma.from_documents(
    documents=documents, 
    embedding=embeddings, 
    persist_directory="../data/austin_chroma_db"
)
print("Vector Database persisted.")

# 2. RAG Reasoning Setup
from langchain_huggingface import HuggingFacePipeline
from transformers import pipeline

# Note: Local LLM path should be updated by the user
# llm = HuggingFacePipeline.from_model_id(model_id="path/to/zephyr-7b-beta", task="text-generation")

# 3. Retrieval Test
query = "Find a safe place near UT Austin with quiet surroundings and park access."
docs = vector_db.similarity_search(query, k=3)

for i, doc in enumerate(docs):
    print(f"Result {i+1}: {doc.page_content[:200]}...")
