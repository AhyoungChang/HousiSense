import pandas as pd
import geopandas as gpd
import h3
import os

# 1. Configuration
DATA_DIR = "../data"
RAW_LISTINGS = os.path.join(DATA_DIR, "raw_listings.csv")
CRIME_DATA = os.path.join(DATA_DIR, "austin_crime_2024.csv")
POI_DATA = os.path.join(DATA_DIR, "austin_pois.csv")
OUTPUT_FILE = os.path.join(DATA_DIR, "austin_spatial_integrated.csv")

# 2. H3 Indexing (Resolution 9: ~250-300m edge length)
# This captures human-scale urban dynamics
def get_h3_index(lat, lon, res=9):
    return h3.latlng_to_cell(lat, lon, res)

print("Processing listing data...")
df = pd.read_csv(RAW_LISTINGS)
df['h3_index'] = df.apply(lambda x: get_h3_index(x['latitude'], x['longitude']), axis=1)

# 3. Spatial Aggregation (Crime & POIs)
# Assign crimes and amenities to hexagonal cells
crime_df = pd.read_csv(CRIME_DATA)
crime_df['h3_index'] = crime_df.apply(lambda x: get_h3_index(x['lat'], x['lon']), axis=1)
crime_counts = crime_df.groupby('h3_index').size().reset_index(name='crime_count')

# 4. Merging Heterogeneous Data
# Fuse listing layer with urban services layer
df_merged = pd.merge(df, crime_counts, on='h3_index', how='left').fillna(0)

# 5. Normalization for Urban Service Profiling
# Convert raw metrics into percentile ranks for relative comparison
cols_to_rank = ['crime_count', 'poi_count', 'dist_park', 'dist_transit']
for col in cols_to_rank:
    df_merged[f'{col}_rank'] = df_merged[col].rank(pct=True)

df_merged.to_csv(OUTPUT_FILE, index=False)
print(f"Preprocessing complete. Saved to {OUTPUT_FILE}")
